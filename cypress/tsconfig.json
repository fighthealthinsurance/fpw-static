{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["es2020", "dom"],
    "types": ["cypress"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true
  },
  "include": ["**/*.ts", "../cypress.config.ts"]
}
